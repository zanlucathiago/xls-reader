{
  "name": "xls-reader",
  "version": "0.1.0",
  "description": "Zero-dependency reader for legacy .xls (BIFF8 / Excel 97-2003) files. Returns each sheet as a grid of typed cells.",
  "keywords": [
    "xls",
    "biff8",
    "excel",
    "spreadsheet",
    "ole2",
    "cfb",
    "legacy-excel",
    "parser",
    "xls-parser",
    "read-xls",
    "sheetjs-alternative",
    "xlrd",
    "zero-dependency",
    "typescript",
    "browser",
    "node"
  ],
  "license": "MIT",
  "author": "Thiago Zanluca",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zanlucathiago/xls-reader.git"
  },
  "bugs": {
    "url": "https://github.com/zanlucathiago/xls-reader/issues"
  },
  "homepage": "https://github.com/zanlucathiago/xls-reader#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.1",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
