{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    // tsup's DTS build injects a default `baseUrl`, which TS 6 deprecates (removed
    // in TS 7). This is the documented escape hatch until tsup stops setting it.
    // Our own config uses no baseUrl. See https://aka.ms/ts6.
    "ignoreDeprecations": "6.0",
    "moduleResolution": "bundler",
    "lib": ["ES2021"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "outDir": "dist"
  },
  "include": ["src", "test"]
}
